# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_HOURS=12
MYSQL_DATABASE=labelwe
MYSQL_USER=labelwe
MYSQL_PASSWORD=replace-with-a-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_PORT=3306
DATABASE_URL=mysql+pymysql://labelwe:replace-with-a-strong-db-password@db:3306/labelwe?charset=utf8mb4
STORAGE_ROOT_NAME=workspace-samples
HOST_STORAGE_ROOT=/data/labelwe/images
HOST_EXPORT_ROOT=/data/labelwe/exports
STORAGE_ROOT=/data/images
EXPORT_ROOT=/data/exports
# Note: STORAGE_ROOT must be writable by backend because XML sidecar files
# are auto-written to the same folder when annotator submits for review.
PUBLIC_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000/api/v1
ALLOW_OPEN_REGISTRATION=false
SEED_DEMO_USERS=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-before-first-start
BOOTSTRAP_ADMIN_DISPLAY_NAME=Platform Admin
CORS_ORIGINS=http://localhost:4173,http://localhost:5173

# Optional: pip mirror settings used during backend image build.
# Keep empty to use default pip index.
# Example (China):
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
